# =============================================================================
# .env.example — MonitoreoFletx
# Copia a .env y completa los valores reales. NUNCA commitear .env.
# Permisos recomendados en el servidor: chmod 600 .env
# =============================================================================

# --- datamart (destino, lectura/escritura) ---
# datarmart01, schema monitoreo_fletx (pre-creado por el DBA; Flyway NO gestiona public).
DATAMART_DB_HOST=localhost
DATAMART_DB_PORT=5438
DATAMART_DB_NAME=monitoreofletx
DATAMART_DB_USERNAME=COMPLETAR
DATAMART_DB_PASSWORD=COMPLETAR
DATAMART_DB_SCHEMA=monitoreo_fletx
# Modo SSL (default: prefer). En produccion usar: require
#DATAMART_DB_SSLMODE=require

# --- Origen Fletx (SOLO LECTURA — sin DDL) ---
ORIGIN_DB_HOST=COMPLETAR
ORIGIN_DB_PORT=5432
ORIGIN_DB_NAME=COMPLETAR
ORIGIN_DB_USERNAME=COMPLETAR
ORIGIN_DB_PASSWORD=COMPLETAR
ORIGIN_DB_SCHEMA=public          # schema del origen en Fletx (default: public)
# Modo SSL (default: prefer). En produccion usar: require
#ORIGIN_DB_SSLMODE=require

# --- Sincronizacion (ventana movil) ---
# Dias hacia atras desde NOW() para la ventana de consulta
SYNC_VENTANA_DIAS=7
# Cron del scheduler (default: cada 15 min). Formato Spring cron de 6 campos.
#SYNC_CRON=0 0/15 * * * *

# --- Management / Actuator ---
# Puerto del actuator/management (default: 8098)
#MANAGEMENT_PORT=8098
